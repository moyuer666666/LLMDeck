{
  "name": "llmdeck-desktop",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --no-open\" \"powershell -Command \"\"Start-Sleep -s 10; electron .\"\"\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package": "yarn build && electron-builder"
  },
  "build": {
    "appId": "com.llmdeck.desktop",
    "productName": "LLMDeck",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@headlessui/tailwindcss": "^0.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.0",
    "@types/react": "18.2.18",
    "@types/react-color": "^3.0.10",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "26.8.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jotai-babel": "^0.1.0",
    "postcss": "^8.4.32",
    "postcss-import": "^15.1.0",
    "postcss-nesting": "^12.0.2",
    "prettier": "^3.1.1",
    "process": "^0.11.10",
    "sass": "^1.69.5",
    "sass-embedded": "^1.99.0",
    "tailwind-scrollbar": "^3.0.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "4.5.1",
    "vite-tsconfig-paths": "^4.2.2"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.1.1",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@sentry/integrations": "^7.90.0",
    "@sentry/react": "^7.90.0",
    "@tanstack/react-router": "^1.43.6",
    "browser-fs-access": "^0.35.0",
    "clsx": "^2.0.0",
    "compare-versions": "^6.1.0",
    "framer-motion": "^10.16.16",
    "highlight.js": "^11.9.0",
    "i18next": "^23.7.11",
    "i18next-browser-languagedetector": "^7.2.0",
    "inter-ui": "^3.19.3",
    "jotai": "^2.6.0",
    "lodash-es": "^4.17.21",
    "ofetch": "^1.3.3",
    "react": "^18.2.0",
    "react-color": "^2.19.3",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^13.5.0",
    "react-icons": "^4.12.0",
    "react-spinners": "^0.13.8",
    "react-textarea-autosize": "^8.5.3",
    "swr": "^2.2.4",
    "tailwind-merge": "^2.1.0",
    "uuid": "^9.0.1"
  },
  "resolutions": {
    "@types/react": "18.2.18",
    "@types/react-dom": "18.2.18"
  },
  "packageManager": "yarn@4.0.1"
}
